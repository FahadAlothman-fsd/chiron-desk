{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.js"
  },
  "dependencies": {
    "@chiron/api": "workspace:*",
    "@chiron/auth": "workspace:*",
    "@chiron/db": "workspace:*",
    "@hono/trpc-server": "^0.4.0",
    "@modelcontextprotocol/sdk": "1.25.2",
    "@opencode-ai/sdk": "^1.1.35",
    "@openrouter/ai-sdk-provider": "catalog:",
    "@trpc/server": "catalog:",
    "ai": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "^1.2.6",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
