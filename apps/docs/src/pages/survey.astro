---
import { getRequiredEnv } from "../lib/server/survey-config";
import { createSurveyLaunch } from "../lib/server/survey-provider";
import { verifyLaunchToken } from "../lib/server/survey-token";

export const prerender = false;

const launchToken = Astro.url.searchParams.get("launchToken");
const tokenSecret = process.env.SURVEY_TOKEN_SECRET ?? process.env.PUBLIC_SURVEY_TEST_SECRET;
const payload =
  launchToken && tokenSecret ? verifyLaunchToken(launchToken, tokenSecret) : null;
const surveyLaunch = payload ? createSurveyLaunch(payload.hiddenFields) : null;
const surveyHref = surveyLaunch?.surveyUrl ?? "#";
const invalidLaunch = Boolean(launchToken) && !payload;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Survey | Chiron Docs</title>
    <link rel="icon" href="/chiron-icon.svg" />
    <style>
      :root {
        color-scheme: dark;
        --bg: #101010;
        --panel: #2a2c29;
        --panel-border: #474741;
        --text: #dddddd;
        --muted: #a7a597;
        --accent: #c4ff58;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: "Commit Mono", "IBM Plex Mono", "SFMono-Regular", ui-monospace, monospace;
        background: var(--bg);
        color: var(--text);
      }

      main {
        width: min(48rem, calc(100vw - 2rem));
        margin: 0 auto;
        padding: 4rem 0 5rem;
      }

      .eyebrow {
        margin: 0 0 1rem;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.8rem;
      }

      h1,
      h2 {
        line-height: 1.2;
      }

      .card {
        margin-top: 2rem;
        padding: 1.5rem;
        border: 1px solid var(--panel-border);
        background: var(--panel);
        border-radius: 1rem;
      }

      code {
        color: var(--accent);
      }

      a {
        color: var(--accent);
      }

      li + li {
        margin-top: 0.5rem;
      }

      p,
      li {
        color: var(--muted);
        line-height: 1.7;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.25rem;
      }

      .button {
        border: 1px solid var(--accent);
        background: var(--accent);
        color: #101010;
        padding: 0.75rem 1rem;
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.75rem;
        font-weight: 700;
      }

      .button.secondary {
        background: transparent;
        color: var(--accent);
      }
    </style>
  </head>
  <body>
    <main>
      <p class="eyebrow">Thesis survey</p>
      <h1>Evaluate Chiron</h1>
      <p>
        This survey is part of a thesis study evaluating Chiron's perceived usefulness
        and novelty in AI-assisted and agentic software development workflows.
      </p>
      <div class="card">
        <h2>Prototype context</h2>
        <p>
          Chiron is currently a prototype. Some parts may feel incomplete, rough, or
          less polished than a production tool. Please answer based on what you
          observed, while distinguishing where possible between the current prototype
          experience and the underlying workflow model: work units, explicit states
          and transitions, workflows, facts, and artifacts.
        </p>
        <p>
          The goal is not to rate Chiron as a finished product, but to understand
          whether this model appears meaningfully different and potentially valuable
          compared with your usual workflow.
        </p>
      </div>
      <div class="card">
        <h2>Before you begin</h2>
        <ul>
          <li>The survey should take about five minutes.</li>
          <li>Do not include private project details or secrets in free-text answers.</li>
          <li>Chiron uses a pseudonymous participant reference for survey tracking.</li>
        </ul>
        {
          invalidLaunch ? (
            <p>
              This survey launch link is invalid or expired. Start again from Chiron so we can
              attach the correct participant and workflow context.
            </p>
          ) : null
        }
        <div class="actions">
          <a
            class="button"
            href={surveyHref}
            aria-disabled={surveyLaunch ? undefined : "true"}
          >
            Start survey
          </a>
          <a class="button secondary" href="/">Back to docs</a>
        </div>
      </div>
    </main>
  </body>
</html>
