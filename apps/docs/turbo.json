{
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "**/*.md", "**/*.mdx", "public/**", "src/**", "astro.config.mjs", "tsconfig.json"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["$TURBO_DEFAULT$", "**/*.md", "**/*.mdx", "public/**", "src/**", "astro.config.mjs", "tsconfig.json"],
      "outputs": []
    }
  }
}
