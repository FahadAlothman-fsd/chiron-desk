          { "id": "setup.confirm", "type": "display", "templateRef": "CFG.DISPLAY.SUMMARY" }
        ]
      }
    },
    {
      "key": "brainstorming",
      "displayName": "Brainstorming",
      "module": "core",
      "ownerWorkUnitRef": "WU.BRAINSTORMING",
      "ownerWorkUnitType": "brainstorming",
      "transition": { "from": "draft", "to": "done" },
      "enabled": true,
      "definitionJson": {
        "id": "brainstorming",
        "name": "brainstorming",
        "steps": [
          {
            "id": "session.intake",
            "type": "agent",
            "templateRef": "CFG.AGENT.INTAKE",
            "overrides": {
              "agentId": "cis-brainstorming-coach",
              "systemPromptRefs": ["BASE.BMAD", "ROLE.cis-brainstorming-coach", "PROMPT.INTAKE_VERBOSE"]
            }
          },
          {
            "id": "techniques.select",
            "type": "agent",
            "templateRef": "CFG.AGENT.ANALYZE",
            "overrides": {
              "agentId": "cis-brainstorming-coach",
              "systemPromptRefs": ["BASE.BMAD", "ROLE.cis-brainstorming-coach", "PROMPT.ANALYZE_VERBOSE"],
              "tools": [
                {
                  "name": "select_techniques",
                  "toolType": "ax-generation",
                  "targetVariable": "fanout.items"
                }
              ]
            }
          },
          {
            "id": "techniques.run",
            "type": "invoke",
            "templateRef": "CFG.INVOKE.SAME",
            "overrides": {
              "forEach": { "itemsVar": "fanout.items", "itemVar": "fanout.item" },
              "workflowRef": { "key": "{{fanout.item}}" },
              "output": { "mode": "namespace", "target": "fanout.outputs" }
            }
          },
          {
            "id": "ideas.converge",
            "type": "agent",
            "templateRef": "CFG.AGENT.GENERATE",
            "overrides": {
              "agentId": "cis-brainstorming-coach",
              "systemPromptRefs": ["BASE.BMAD", "ROLE.cis-brainstorming-coach", "PROMPT.CONVERGE_VERBOSE"],
              "tools": [{ "name": "update_idea_summary", "toolType": "update-variable", "targetVariable": "draft.markdown" }]
            }
          },
          { "id": "persist.artifact", "type": "action", "templateRef": "CFG.ACTION.PERSIST" },
          { "id": "done.show", "type": "display", "templateRef": "CFG.DISPLAY.SUMMARY" }
        ]
      }
    },
    {
      "key": "party-mode",
      "displayName": "Party Mode",
