{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "bash": {
      "npm run dev": "ask",
      "npm run tauri dev": "ask",
      "bun run dev": "ask",
      "bun run tauri dev": "ask",
      "*": "allow"
    }
  },
  "mcp": {
    "browser": {
      "type": "local",
      "command": [
        "bun",
        "x",
        "@agent-infra/mcp-server-browser@latest"
      ],
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-614ac792-581e-422d-9238-20ed761fd718"
      },
      "enabled": true
    }
  }
}
