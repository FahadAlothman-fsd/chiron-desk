{
  "name": "@chiron/scripts",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "test": "bunx vitest run",
    "module:wiring-smoke": "bun run src/module-wiring-smoke.ts",
    "db:seed": "DOTENV_CONFIG_PATH=../../apps/server/.env bun run src/seed.mjs",
    "db:seed:reset": "DOTENV_CONFIG_PATH=../../apps/server/.env bun run src/seed.mjs --reset",
    "db:seed:story": "DOTENV_CONFIG_PATH=../../apps/server/.env bun run src/story-seed.mjs",
    "db:seed:story:reset": "DOTENV_CONFIG_PATH=../../apps/server/.env bun run src/story-seed.mjs --reset"
  },
  "dependencies": {
    "@chiron/agent-runtime": "workspace:*",
    "@chiron/auth": "workspace:*",
    "@chiron/ax-engine": "workspace:*",
    "@chiron/contracts": "workspace:*",
    "@chiron/db": "workspace:*",
    "@chiron/event-bus": "workspace:*",
    "@chiron/methodology-engine": "workspace:*",
    "@chiron/provider-registry": "workspace:*",
    "@chiron/sandbox-engine": "workspace:*",
    "@chiron/template-engine": "workspace:*",
    "@chiron/tooling-engine": "workspace:*",
    "@chiron/variable-service": "workspace:*",
    "@chiron/workflow-engine": "workspace:*",
    "@effect/cli": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/printer": "catalog:",
    "@effect/printer-ansi": "catalog:",
    "better-result": "^2.7.0",
    "drizzle-orm": "^0.45.1",
    "drizzle-seed": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@chiron/config": "workspace:*",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
