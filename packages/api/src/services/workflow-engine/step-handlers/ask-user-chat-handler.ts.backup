import type { AskUserChatStepConfig, WorkflowStep } from "@chiron/db";
import type { ExecutionContext } from "../execution-context";
import type { StepHandler, StepResult } from "../step-handler";
import { RuntimeContext } from "@mastra/core";
import {
	getMastraInstance,
	createThread,
	getThread,
} from "../../mastra/mastra-service";
import { db, agents } from "@chiron/db";
import { eq } from "drizzle-orm";
import {
	buildAxGenerationTool,
	validateRequiredVariables as validateAxRequiredVariables,
} from "../tools/ax-generation-tool";
import {
	buildDatabaseQueryTool,
	validateRequiredVariables as validateDbRequiredVariables,
} from "../tools/database-query-tool";
import {
	buildSelectPathTool,
	buildGenerateProjectNameTool,
} from "../tools/custom";

/**
 * AskUserChatStepHandler - Conversational chat interface with AI agent
 *
 * Architecture: Uses registered Mastra agents with dynamic configuration
 *
 * This handler uses agents registered with Mastra at startup. Agent configuration
 * (instructions, model, tools) is loaded dynamically via RuntimeContext on each call,
 * allowing for real-time updates without server restarts.
 *
 * Features:
 * - Registered agents with dynamic configuration via RuntimeContext
 * - Automatic conversation history loading by Mastra
 * - ACE playbook injection based on scope (global/user/project)
 * - User-specific API key loading per request
 * - Thread management for conversation persistence
 * - Completion condition checking
 *
 * @see docs/architecture/dynamic-agent-registration.md
 * @see docs/architecture/STORY-1-6-ARCHITECTURE-SUMMARY.md
 */
export class AskUserChatStepHandler implements StepHandler {
	constructor() {
		// No longer need ACE optimizer - handled in agent-loader
	}

	async executeStep(
		step: WorkflowStep,
		context: ExecutionContext,
		userInput?: unknown,
	): Promise<StepResult> {
		const config = step.config as AskUserChatStepConfig;

		console.log(
			"[AskUserChatHandler] executeStep called",
			"userInput:",
			userInput,
		);

		// Initialize or load Mastra agent and thread
		const agentContext = await this.initializeAgent(config, context);

		// Save thread ID to execution variables if new thread created
		const output: Record<string, unknown> = {};
		if (agentContext.needsSave) {
			output.mastra_thread_id = agentContext.threadId;
		}

		// If no user input, show initial message and wait
		if (!userInput) {
			console.log(
				"[AskUserChatHandler] No user input - awaiting first message",
			);
			return {
				output: {
					...output,
					agent_context: {
						threadId: agentContext.threadId,
						instructions: agentContext.instructions,
					},
					initial_message: config.initialMessage,
				},
				nextStepNumber: step.nextStepNumber ?? null,
				requiresUserInput: true,
			};
		}

		// If user input provided, process it through agent
		if (userInput) {
			console.log("[AskUserChatHandler] Processing user message:", userInput);

			// Get registered agent from Mastra
			const mastra = await getMastraInstance();
			const [agentRecord] = await db
				.select()
				.from(agents)
				.where(eq(agents.id, config.agentId));

			if (!agentRecord) {
				throw new Error(`Agent not found: ${config.agentId}`);
			}

			const agent = mastra.getAgent(agentRecord.name);
			if (!agent) {
				throw new Error(
					`Agent not registered with Mastra: ${agentRecord.name}`,
				);
			}

			// Create RuntimeContext with required data for dynamic loading
			const runtimeContext = new RuntimeContext();
			runtimeContext.set("userId", context.systemVariables.current_user_id);
			runtimeContext.set("agentId", config.agentId);
			runtimeContext.set("projectId", context.variables.project_id);
			runtimeContext.set("variables", context.variables);

			const threadId = agentContext.threadId;
			const userId = context.systemVariables.current_user_id as string;

			// Call agent with RuntimeContext - Mastra handles conversation history automatically
			console.log(
				"[AskUserChatHandler] Calling registered agent with RuntimeContext...",
			);
			const result = await agent.generate(String(userInput), {
				memory: {
					thread: threadId,
					resource: `user-${userId}`,
				},
				runtimeContext, // Triggers dynamic loading of instructions, model, tools
				maxSteps: 5,
			});

			console.log("[AskUserChatHandler] Agent response received:", result.text);

			// Mastra automatically saves messages when agent is registered
			// No manual saving needed!
		}

		// Check if step is complete
		const isComplete = await this.checkCompletionCondition(config, context);

		if (isComplete) {
			// Extract output variables
			const outputs = this.extractOutputVariables(config, context);
			return {
				output: {
					...outputs,
					...output, // Include thread ID if it was just created
					mastra_thread_id: agentContext.threadId, // Always include thread ID
				},
				nextStepNumber: step.nextStepNumber ?? null,
				requiresUserInput: false,
			};
		}

		// Step not complete, wait for more user input
		return {
			output: {
				...output, // Include thread ID if it was just created
				mastra_thread_id: agentContext.threadId, // Always include thread ID for message retrieval
			},
			nextStepNumber: step.nextStepNumber ?? null,
			requiresUserInput: true,
		};
	}

	/**
	 * Initialize or resume Mastra agent from config
	 *
	 * - Loads agent instructions from database
	 * - Loads ACE playbook and injects into instructions
	 * - Creates or loads Mastra thread
	 * - Saves thread ID to execution variables
	 * - Builds tools from config
	 * - Returns agent context
	 */
	private async initializeAgent(
		config: AskUserChatStepConfig,
		context: ExecutionContext,
	): Promise<{
		agent: Agent;
		threadId: string;
		instructions: string;
		needsSave: boolean;
	}> {
		// Load agent from database
		const [agentRecord] = await db
			.select()
			.from(agents)
			.where(eq(agents.id, config.agentId));

		if (!agentRecord) {
			throw new Error(`Agent not found: ${config.agentId}`);
		}

		// Load ACE playbook
		const playbook = await this.aceOptimizer.loadPlaybook(
			config.agentId,
			"global", // TODO: Support user/project scopes
		);

		// Build instructions with ACE playbook
		let instructions = agentRecord.instructions || "";
		if (playbook) {
			const playbookSection =
				this.aceOptimizer.formatPlaybookForPrompt(playbook);
			instructions += playbookSection;
		}

		// Get or create Mastra thread
		let threadId = context.executionVariables.mastra_thread_id as
			| string
			| undefined;
		let needsSave = false;

		if (!threadId) {
			const thread = await createThread(
				`user-${context.systemVariables.current_user_id}`,
			);
			threadId = thread.id;
			needsSave = true; // Need to save thread ID to execution variables
			console.log("[AskUserChatHandler] Created new thread:", threadId);
		} else {
			// Verify thread exists
			const thread = await getThread(threadId);
			if (!thread) {
				// Thread not found, create new one
				const newThread = await createThread(
					`user-${context.systemVariables.current_user_id}`,
				);
				threadId = newThread.id;
				needsSave = true;
				console.log(
					"[AskUserChatHandler] Thread not found, created new:",
					threadId,
				);
			}
		}

		// Build tools from config
		const tools = await this.buildTools(
			config.tools || [],
			context,
			config.agentId,
		);

		// Create Mastra agent with model configuration
		const mastra = await getMastraInstance();

		// Load model from agent configuration (or use default)
		const modelConfig = parseModelConfig(agentRecord.llmModel);
		console.log(
			`[AskUserChatHandler] Using model: ${modelConfig.provider}:${modelConfig.modelId}`,
		);

		// Load user's API key from database
		const userId = context.systemVariables.current_user_id as string;
		console.log(
			`[AskUserChatHandler] Loading API key for user: ${userId}, provider: ${modelConfig.provider}`,
		);

		const [userConfig] = await db
			.select()
			.from(appConfig)
			.where(eq(appConfig.userId, userId));

		console.log(
			`[AskUserChatHandler] User config found: ${!!userConfig}, has openrouterApiKey: ${!!userConfig?.openrouterApiKey}`,
		);

		if (userConfig) {
			// Decrypt and use the appropriate API key based on provider
			let apiKey: string | undefined;
			if (
				modelConfig.provider === "openrouter" &&
				userConfig.openrouterApiKey
			) {
				apiKey = decrypt(userConfig.openrouterApiKey);
				console.log(
					`[AskUserChatHandler] Decrypted OpenRouter API key: ${apiKey?.substring(0, 10)}...`,
				);
			} else if (
				modelConfig.provider === "anthropic" &&
				userConfig.anthropicApiKey
			) {
				apiKey = decrypt(userConfig.anthropicApiKey);
				console.log(
					`[AskUserChatHandler] Decrypted Anthropic API key: ${apiKey?.substring(0, 10)}...`,
				);
			} else if (modelConfig.provider === "openai" && userConfig.openaiApiKey) {
				apiKey = decrypt(userConfig.openaiApiKey);
				console.log(
					`[AskUserChatHandler] Decrypted OpenAI API key: ${apiKey?.substring(0, 10)}...`,
				);
			}

			if (apiKey) {
				modelConfig.apiKey = apiKey;
				console.log(
					`[AskUserChatHandler] ✓ Successfully loaded user's ${modelConfig.provider} API key from database`,
				);
			} else {
				console.warn(
					`[AskUserChatHandler] ⚠ No API key found for provider: ${modelConfig.provider}`,
				);
			}
		} else {
			console.warn(
				`[AskUserChatHandler] ⚠ No user config found for userId: ${userId}`,
			);
		}

		console.log(
			`[AskUserChatHandler] Final modelConfig being passed to loadModel():`,
			{
				provider: modelConfig.provider,
				modelId: modelConfig.modelId,
				hasApiKey: !!modelConfig.apiKey,
				apiKeyPrefix: modelConfig.apiKey?.substring(0, 10),
			},
		);

		const model = loadModel(modelConfig);

		// Get Mastra storage for memory
		const mastra = await getMastraInstance();
		const storage = mastra.getStorage();

		// Create agent with memory configured to use Mastra storage
		// Memory must use the same storage instance for automatic conversation history
		const agent = new Agent({
			name: agentRecord.name,
			instructions: instructions,
			model,
			tools: Object.fromEntries(tools.map((t) => [t.name, t as any])),
			memory: storage
				? new Memory({
						storage: storage as any, // Use Mastra's PostgresStore
						options: {
							lastMessages: 50, // Include last 50 messages for context
						},
					})
				: undefined,
		});

		console.log(
			`[AskUserChatHandler] Agent created with memory:`,
			!!agent.memory,
		);

		return {
			agent,
			threadId,
			instructions,
			needsSave,
		};
	}

	/**
	 * Build Mastra tools from config
	 *
	 * For each tool in config:
	 * 1. Validate required variables exist
	 * 2. Build tool based on toolType (ax-generation, database-query, custom)
	 * 3. Return tool definition objects
	 *
	 * @param toolConfigs - Tool configurations from step config
	 * @param context - Execution context
	 * @param agentId - Agent ID for ACE playbook loading
	 * @returns Array of tool definitions
	 */
	private async buildTools(
		toolConfigs: NonNullable<AskUserChatStepConfig["tools"]>,
		context: ExecutionContext,
		agentId: string,
	): Promise<
		Array<{
			name: string;
			description: string;
			execute: (input: unknown) => Promise<unknown>;
		}>
	> {
		const tools: Array<{
			name: string;
			description: string;
			execute: (input: unknown) => Promise<unknown>;
		}> = [];

		for (const toolConfig of toolConfigs) {
			// Validate required variables
			let validation: { valid: boolean; missingVariables?: string[] };

			if (toolConfig.toolType === "ax-generation") {
				validation = validateAxRequiredVariables(
					toolConfig.requiredVariables,
					context,
				);
			} else if (toolConfig.toolType === "database-query") {
				validation = validateDbRequiredVariables(
					toolConfig.requiredVariables,
					context,
				);
			} else {
				// Custom tools - skip validation for now
				validation = { valid: true };
			}

			if (!validation.valid) {
				console.warn(
					`[AskUserChatHandler] Tool "${toolConfig.name}" missing required variables: ${validation.missingVariables?.join(", ")}`,
				);
				// Skip tool if prerequisites not met
				continue;
			}

			// Build tool based on type
			switch (toolConfig.toolType) {
				case "ax-generation": {
					const tool = await buildAxGenerationTool(
						toolConfig,
						context,
						agentId,
					);
					tools.push(tool);
					break;
				}

				case "database-query": {
					const tool = await buildDatabaseQueryTool(toolConfig, context);
					tools.push(tool);
					break;
				}

				case "custom": {
					// Build custom tool based on handler name
					const handlerName = toolConfig.customToolHandler;

					if (handlerName === "select_workflow_path") {
						const tool = await buildSelectPathTool(toolConfig, context);
						tools.push(tool);
					} else if (handlerName === "generate_project_name") {
						const tool = await buildGenerateProjectNameTool(
							toolConfig,
							context,
						);
						tools.push(tool);
					} else {
						console.warn(
							`[AskUserChatHandler] Unknown custom tool handler: ${handlerName}`,
						);
					}
					break;
				}

				default:
					throw new Error(`Unknown tool type: ${(toolConfig as any).toolType}`);
			}
		}

		console.log(
			`[AskUserChatHandler] Built ${tools.length} tools from ${toolConfigs.length} configs`,
		);

		return tools;
	}

	/**
	 * Check if step completion condition is satisfied
	 *
	 * Supports:
	 * - all-tools-approved: All required tools have been approved
	 * - user-satisfied: User explicitly says they're done (future)
	 * - max-turns: Maximum conversation turns reached (future)
	 * - confidence-threshold: AI confidence threshold (future)
	 */
	private async checkCompletionCondition(
		config: AskUserChatStepConfig,
		context: ExecutionContext,
	): Promise<boolean> {
		const condition = config.completionCondition;

		switch (condition.type) {
			case "all-tools-approved": {
				const requiredTools = condition.requiredTools || [];
				const approvalStates = (context.executionVariables.approval_states ||
					{}) as Record<
					string,
					{ status: "pending" | "approved" | "rejected" }
				>;

				// Check if all required tools have been approved
				return requiredTools.every((toolName) => {
					const state = approvalStates[toolName];
					return state && state.status === "approved";
				});
			}

			case "user-satisfied":
			case "max-turns":
			case "confidence-threshold":
				// TODO: Implement these conditions in future iterations
				console.warn(
					`[AskUserChatHandler] Completion condition "${condition.type}" not yet implemented`,
				);
				return false;

			default:
				throw new Error(
					`Unknown completion condition type: ${(condition as any).type}`,
				);
		}
	}

	/**
	 * Extract output variables from approval states
	 *
	 * Maps output variable names to their values from approval_states
	 * Example: { project_description: "approval_states.update_summary.value" }
	 */
	private extractOutputVariables(
		config: AskUserChatStepConfig,
		context: ExecutionContext,
	): Record<string, unknown> {
		if (!config.outputVariables) {
			return {};
		}

		const outputs: Record<string, unknown> = {};
		const approvalStates = (context.executionVariables.approval_states ||
			{}) as Record<string, { value: unknown }>;

		for (const [outputName, path] of Object.entries(config.outputVariables)) {
			// Parse path like "approval_states.update_summary.value"
			if (typeof path !== "string") {
				console.warn(
					`[AskUserChatHandler] Invalid output variable path type: ${typeof path}`,
				);
				continue;
			}

			const pathParts = path.split(".");
			if (
				pathParts.length === 3 &&
				pathParts[0] === "approval_states" &&
				pathParts[2] === "value"
			) {
				const toolName = pathParts[1];
				if (toolName) {
					const state = approvalStates[toolName];
					if (state && state.value !== undefined) {
						outputs[outputName] = state.value;
					}
				}
			} else {
				console.warn(
					`[AskUserChatHandler] Unsupported output variable path: ${path}`,
				);
			}
		}

		return outputs;
	}
}
