{
  "name": "@chiron/contracts",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "default": "./dist/src/index.js"
    },
    "./desktop-runtime": {
      "types": "./src/desktop-runtime.ts",
      "bun": "./src/desktop-runtime.ts",
      "default": "./dist/src/desktop-runtime.js"
    },
    "./*": {
      "types": "./src/*.ts",
      "bun": "./src/*.ts",
      "default": "./dist/src/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "@chiron/config": "workspace:*",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
