{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["AI_RUNTIME_DEBUG_TOOL_STREAM"],
      "passThroughEnv": ["AI_RUNTIME_DEBUG_TOOL_STREAM"]
    },
    "desktop:dev": {
      "cache": false,
      "persistent": true,
      "env": ["XAUTHORITY", "DISPLAY"]
    },
    "db:push": {
      "cache": false,
      "persistent": true
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false,
      "persistent": true
    },
    "db:start": {
      "cache": false,
      "persistent": true
    },
    "db:stop": {
      "cache": false,
      "persistent": true
    },
    "db:watch": {
      "cache": false,
      "persistent": true
    },
    "db:down": {
      "cache": false,
      "persistent": true
    },
    "seed": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "db:reset": {
      "cache": false,
      "persistent": true,
      "interactive": true
    }
  }
}
