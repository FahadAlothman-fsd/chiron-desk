{
  "name": "chiron",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@orpc/server": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "better-auth": "^1.4.18",
      "@libsql/client": "0.15.15",
      "libsql": "0.5.22",
      "@orpc/client": "^1.12.2",
      "vitest": "^3.2.4",
      "@vitest/coverage-v8": "^3.2.4",
      "effect": "^3.19.16",
      "@effect/cli": "^0.73.2",
      "@effect/platform": "^0.94.3",
      "@effect/printer": "^0.47.0",
      "@effect/printer-ansi": "^0.47.0",
      "@xyflow/react": "^12",
      "@tanstack/react-hotkeys": "^0.3.0",
      "drizzle-seed": "^0.3.1"
    }
  },
  "type": "module",
  "scripts": {
    "prepare": "lefthook install && effect-language-service patch",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev --filter=web",
    "dev:server": "turbo run dev --filter=server",
    "dev:docs": "turbo run dev --filter=docs",
    "build:docs": "turbo run build --filter=docs",
    "report:figures": "bash academic_reports/render-mermaid.sh",
    "report:build": "bash academic_reports/build-report.sh pdf",
    "report:html": "bash academic_reports/build-report.sh html",
    "report:docx": "bash academic_reports/build-report.sh docx",
    "preview:docs": "turbo run preview --filter=docs",
    "db:push": "turbo run db:push --filter=@chiron/db",
    "db:studio": "turbo run db:studio --filter=@chiron/db",
    "db:generate": "turbo run db:generate --filter=@chiron/db",
    "db:migrate": "turbo run db:migrate --filter=@chiron/db",
    "db:local": "turbo run db:local --filter=@chiron/db",
    "db:seed": "bun run db:push && turbo run db:seed --filter=@chiron/scripts",
    "db:seed:reset": "bun run db:push && turbo run db:seed:reset --filter=@chiron/scripts",
    "db:seed:test": "bun run db:push && turbo run db:seed:test --filter=@chiron/scripts",
    "db:seed:test:reset": "bun -e \"import { rmSync } from 'node:fs'; rmSync('local.db', { force: true });\" && bun run db:push && turbo run db:seed:test:reset --filter=@chiron/scripts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "check": "bun run lint && bun run format:check",
    "test": "turbo run test",
    "test:layout:guardrail": "bun scripts/test-layout-guardrail.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:docs": "bun run test:docs:smoke",
    "test:docs:smoke": "playwright test -c playwright.docs.config.ts",
    "test:docs:headed": "playwright test -c playwright.docs.config.ts --headed",
    "test:docs:ui": "playwright test -c playwright.docs.config.ts --ui"
  },
  "dependencies": {
    "@chiron/env": "workspace:*",
    "better-result": "^2.7.0",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@chiron/config": "workspace:*",
    "@effect/language-service": "^0.80.0",
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.58.2",
    "@seontechnologies/playwright-utils": "^3.14.0",
    "@types/bun": "catalog:",
    "lefthook": "^2.0.13",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.9"
}
