{
  "name": "chiron",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "ai": "^6.0.39",
      "@ai-sdk/anthropic": "^2.0.44",
      "@ai-sdk/openai": "^2.0.65",
      "@openrouter/ai-sdk-provider": "^1.2.2",
      "effect": "^3.14.0",
      "hono": "^4.8.2",
      "@trpc/server": "^11.5.0",
      "better-auth": "^1.3.28",
      "dotenv": "^17.2.2",
      "zod": "^4.1.11",
      "typescript": "^5.8.2",
      "tsdown": "^0.15.5",
      "@trpc/client": "^11.5.0"
    }
  },
  "type": "module",
  "scripts": {
    "check": "oxlint && oxfmt --check .",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "prepare": "husky",
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "DATABASE_URL=postgresql://postgres:password@localhost:5434/chiron bun test --preload ./apps/web/test-setup.ts",
    "test:scripts": "DATABASE_URL=postgresql://postgres:password@localhost:5434/chiron bun test packages/scripts/src/**/*.test.ts",
    "test:db": "DATABASE_URL=postgresql://postgres:password@localhost:5434/chiron bun test packages/db/src/**/*.test.ts",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F web desktop:dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:reset": "turbo -F @chiron/scripts db:reset",
    "db:push": "turbo -F @chiron/db db:push",
    "db:studio": "turbo -F @chiron/db db:studio",
    "db:generate": "turbo -F @chiron/db db:generate",
    "db:migrate": "turbo -F @chiron/db db:migrate",
    "db:start": "turbo -F @chiron/db db:start",
    "db:watch": "turbo -F @chiron/db db:watch",
    "db:stop": "turbo -F @chiron/db db:stop",
    "db:down": "turbo -F @chiron/db db:down",
    "db:seed": "turbo -F @chiron/scripts seed",
    "db:seed:reset": "turbo -F @chiron/scripts seed -- --reset"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "catalog:",
    "@ai-sdk/openai": "catalog:",
    "@ax-llm/ax": "^14.0.39",
    "@openrouter/ai-sdk-provider": "catalog:",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@trpc/react-query": "^11.7.1",
    "ai": "catalog:",
    "ai-sdk-provider-opencode-sdk": "^1.0.0",
    "cmdk": "^1.1.1",
    "deepmerge": "^4.3.1",
    "dotenv": "^17.2.2",
    "effect": "^3.14.0",
    "handlebars": "^4.7.8",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "nanoid": "^5.1.6",
    "pg": "^8.16.3",
    "streamdown": "^1.4.0",
    "use-stick-to-bottom": "^1.1.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/bun": "^1.2.6",
    "@types/deepmerge": "^2.2.3",
    "@types/pg": "^8.15.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "oxfmt": "^0.24.0",
    "oxlint": "^1.39.0",
    "tsdown": "^0.15.5",
    "turbo": "^2.5.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt --write"
    ]
  },
  "packageManager": "bun@1.3.0"
}
