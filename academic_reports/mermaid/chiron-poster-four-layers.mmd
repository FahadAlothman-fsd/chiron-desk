flowchart LR
    P[PROJECT LAYER<br/>project context • methodology version • project facts]
    WU[WORK UNIT LAYER<br/>state • facts • transitions • gates • artifacts]
    WF[WORKFLOW LAYER<br/>steps • routes • context facts • progression]
    ST[STEP LAYER<br/>agent • form • branch • action • invoke • display]

    P ==> WU
    WU ==> WF
    WF ==> ST

    P1[SOLVES<br/>governed project context]
    WU1[SOLVES<br/>durable lifecycle contract]
    WF1[SOLVES<br/>explicit progression]
    ST1[SOLVES<br/>typed execution]

    P -.-> P1
    WU -.-> WU1
    WF -.-> WF1
    ST -.-> ST1

    linkStyle 0,1,2 stroke:#111827,stroke-width:7px;
    linkStyle 3,4,5,6 stroke:#64748b,stroke-width:3px,stroke-dasharray: 8 4;

    classDef project fill:#f6f2df,stroke:#b59d3b,color:#5b4b16,stroke-width:5px,font-size:32px;
    classDef workunit fill:#ccfbf1,stroke:#0f766e,color:#134e4a,stroke-width:5px,font-size:32px;
    classDef workflow fill:#dbeafe,stroke:#2563eb,color:#1e3a8a,stroke-width:5px,font-size:32px;
    classDef step fill:#ffedd5,stroke:#ea580c,color:#7c2d12,stroke-width:5px,font-size:32px;
    classDef notes fill:#ffffff,stroke:#94a3b8,color:#334155,stroke-width:2px,font-size:22px;

    class P project;
    class WU workunit;
    class WF workflow;
    class ST step;
    class P1,WU1,WF1,ST1 notes;
