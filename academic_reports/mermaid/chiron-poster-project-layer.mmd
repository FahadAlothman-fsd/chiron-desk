flowchart TB
    subgraph P[PROJECT LAYER]
        direction TB
        P0[project context<br/>methodology version<br/>project facts<br/>runtime evidence]

        subgraph WU[WORK UNIT LAYER]
            direction TB
            W0[WORK UNIT LAYER]

            subgraph WF[WORKFLOW LAYER]
