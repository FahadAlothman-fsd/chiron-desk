    linkStyle 0,1,2,3 stroke:#111827,stroke-width:7px;
    linkStyle 4 stroke:#64748b,stroke-width:3px,stroke-dasharray: 8 4;

    classDef state fill:#ccfbf1,stroke:#0f766e,color:#134e4a,stroke-width:5px,font-size:32px;
    classDef gate fill:#ffedd5,stroke:#ea580c,color:#7c2d12,stroke-width:5px,font-size:32px;
    classDef flow fill:#dbeafe,stroke:#2563eb,color:#1e3a8a,stroke-width:5px,font-size:32px;
    classDef note fill:#ffffff,stroke:#94a3b8,color:#334155,stroke-width:2px,font-size:22px;

    class S1,S2 state;
    class T1,T2 gate;
    class W1 flow;
    class N1 note;
